# ── Code Signing ──────────────────────────────────────────────────────
# Developer ID Application certificate identity (e.g. "Developer ID Application: Your Name (TEAMID)"), 
# could be found with `security find-identity -v -p codesigning`.
# Required for proper signing. If not set, ad-hoc signing is used.
ICHR_SIGNING_IDENTITY=

# ── Notarization ─────────────────────────────────────────────────────
# Option A: Keychain profile (preferred)
# Store credentials first with:
#   xcrun notarytool store-credentials "PROFILE_NAME" \
#     --apple-id "you@example.com" \
#     --team-id "XXXXXXXXXX" \
#     --password "xxxx-xxxx-xxxx-xxxx"
# Then set the profile name here:
ICHR_NOTARY_PROFILE=

# Option B: Inline credentials (fallback if no keychain profile)
# ICHR_APPLE_ID=you@example.com
# ICHR_TEAM_ID=XXXXXXXXXX
# ICHR_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
